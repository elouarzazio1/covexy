{
  "name": "covexy",
  "version": "2.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg"
  },
  "keywords": [],
  "author": "Othmane El Ouarzazi",
  "license": "ISC",
  "description": "A silent AI that watches your screen and acts proactively",
  "build": {
    "afterPack": "./scripts/afterPack.js",
    "appId": "com.covexy.app",
    "productName": "Covexy",
    "copyright": "Copyright 2026 Othmane El Ouarzazi",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/covexy.icns",
      "identity": null,
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "Covexy",
      "backgroundColor": "#141414",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 390,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,__pycache__,thumbs.db,.gitignore,.gitattributes}",
      "!covexy-error.log"
    ]
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "node-record-lpcm16": "^1.0.1",
    "screenshot-desktop": "^1.12.7"
  }
}
